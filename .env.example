# Xero API Configuration for Custom Connections
XERO_CLIENT_ID=your_client_id_here
XERO_CLIENT_SECRET=your_client_secret_here

# Alternatively, use a pre-obtained Bearer Token
# XERO_CLIENT_BEARER_TOKEN=your_bearer_token_here

# Authorization Code flow with PKCE (for multi-tenant / partner apps)
# Set XERO_AUTH_MODE=auth_code to enable. Requires XERO_CLIENT_ID and XERO_CLIENT_SECRET.
# Register http://localhost:3000/callback as a redirect URI in your Xero app.
# XERO_AUTH_MODE=auth_code
# XERO_CALLBACK_PORT=3000
# XERO_TOKEN_STORE_PATH=~/.xero-mcp/tokens.json 